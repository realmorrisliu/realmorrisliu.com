---
import Link from "@components/Link.astro";
import ResumePdfCompiler from "@components/ResumePdfCompiler.astro";
import { getHtmlLangAttribute, getTranslations, type Language } from "@i18n/utils";
import { getResumeTypstAssetUrls } from "@utils/resumeTypstAssets";
import "@styles/global.css";

export interface Props {
  currentLang: Language;
}

const { currentLang } = Astro.props;
const t = getTranslations(currentLang);
const htmlLang = getHtmlLangAttribute(currentLang);

const pageTitle = t.soFar.pdf.pageTitle;
const pageDescription = t.soFar.pdf.pageDescription;
const backUrl = currentLang === "zh" ? "/so-far/zh" : "/so-far";

const pathname = Astro.url.pathname.replace(/\.html$/, "").replace(/\/$/, "");
const canonicalURL = new URL(pathname, Astro.site || "https://realmorrisliu.com");

const alternateLanguages =
  currentLang === "en"
    ? [{ lang: "zh", url: "https://realmorrisliu.com/so-far/pdf/zh" }]
    : [{ lang: "en", url: "https://realmorrisliu.com/so-far/pdf" }];

const backLabel = t.soFar.pdf.backText;
const downloadLabel = t.soFar.pdf.printButton;
const languageSwitchLabel = currentLang === "zh" ? "切换简历语言" : "Switch resume language";
const renderNote =
  currentLang === "zh"
    ? "此页面在浏览器中使用 Typst 渲染简历，并可直接导出为 PDF。"
    : "This page renders the resume in your browser with Typst and exports it directly as a PDF.";
const enLanguageClass =
  currentLang === "en" ? "pdf-language-option is-active" : "pdf-language-option";
const zhLanguageClass =
  currentLang === "zh" ? "pdf-language-option is-active" : "pdf-language-option";
const { previewUrl } = getResumeTypstAssetUrls(currentLang);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={pageDescription} />
    <meta
      name="keywords"
      content="Morris Liu, Resume, PDF, Full-Stack Engineer, Technical Leader"
    />
    <meta name="author" content="Morris Liu" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content="https://realmorrisliu.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Morris Liu - Resume" />
    <meta property="og:site_name" content="Morris Liu" />
    <meta property="og:locale" content={currentLang === "zh" ? "zh_CN" : "en_US"} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={pageDescription} />
    <meta property="twitter:image" content="https://realmorrisliu.com/og-image.png" />
    <meta property="twitter:image:alt" content="Morris Liu - Resume" />
    <meta property="twitter:creator" content="@realmorrisliu" />

    <meta name="theme-color" content="#ffffff" />
    <meta name="msapplication-TileColor" content="#ffffff" />
    <link rel="preload" href={previewUrl} as="image" type="image/svg+xml" />

    {
      alternateLanguages.map(({ lang: hrefLang, url }) => (
        <link rel="alternate" hreflang={hrefLang} href={url} />
      ))
    }
    <link rel="alternate" hreflang={currentLang} href={canonicalURL.toString()} />
    <link rel="alternate" type="application/rss+xml" title="Morris Liu's Blog" href="/rss.xml" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />
  </head>

  <body class="text-text-primary m-0 min-h-full w-full bg-[#f3f3f3] font-sans print:bg-white">
    <main
      class="min-h-screen overflow-auto px-4 py-5 sm:px-6 lg:h-screen lg:px-8 lg:py-8 print:block print:h-auto print:overflow-visible print:bg-white print:p-0"
      aria-label={pageTitle}
    >
      <div class="pdf-page-shell mx-auto">
        <nav
          class="pdf-top-tools print:hidden"
          aria-label={currentLang === "zh" ? "PDF 操作" : "PDF actions"}
        >
          <Link href={backUrl} class="text-sm whitespace-nowrap">{backLabel}</Link>

          <div class="pdf-top-actions">
            <button
              id="print-button"
              class="pdf-letter-action"
              type="button"
              title={t.soFar.pdf.printButton}
              aria-label={t.soFar.pdf.printButton}
            >
              {downloadLabel}
            </button>

            <div class="pdf-language-switch" aria-label={languageSwitchLabel}>
              <a
                href="/so-far/pdf"
                class={enLanguageClass}
                aria-current={currentLang === "en" ? "page" : undefined}
              >
                EN
              </a>
              <span class="pdf-language-separator" aria-hidden="true">/</span>
              <a
                href="/so-far/pdf/zh"
                class={zhLanguageClass}
                aria-current={currentLang === "zh" ? "page" : undefined}
              >
                中
              </a>
            </div>
          </div>
        </nav>

        <ResumePdfCompiler currentLang={currentLang} />

        <p class="pdf-render-note print:hidden">{renderNote}</p>
      </div>
    </main>
  </body>
</html>

<style>
  @media print {
    @page {
      margin: 0mm;
      size: A4;
    }

    #resume-pdf-app {
      box-shadow: none !important;
    }
  }

  .pdf-letter-action {
    display: inline-flex;
    align-items: center;
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--color-text-secondary);
    font: inherit;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
    text-align: left;
    text-decoration-line: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    white-space: nowrap;
    cursor: pointer;
    transition:
      color 150ms ease,
      opacity 150ms ease;
  }

  .pdf-letter-action:hover {
    color: var(--color-text-primary);
  }

  .pdf-letter-action:disabled {
    cursor: wait;
    opacity: 0.45;
  }

  .pdf-letter-action:focus-visible {
    outline: 2px solid var(--color-text-primary);
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
  }

  .pdf-page-shell {
    width: 210mm;
    min-width: 210mm;
  }

  .pdf-top-tools {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .pdf-top-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .pdf-language-switch {
    display: inline-flex;
    align-items: baseline;
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
  }

  .pdf-language-option {
    color: var(--color-text-tertiary);
    text-decoration: none;
    opacity: 0.5;
    transition:
      color 150ms ease,
      opacity 150ms ease;
  }

  .pdf-language-option:hover {
    color: var(--color-text-secondary);
    opacity: 0.85;
  }

  .pdf-language-option.is-active {
    color: var(--color-text-primary);
    opacity: 1;
  }

  .pdf-language-separator {
    margin: 0 0.1875rem;
    color: var(--color-text-tertiary);
    opacity: 0.45;
  }

  .pdf-render-note {
    margin: 0.875rem 0 0;
    color: var(--color-text-tertiary);
    font-size: 0.8125rem;
    line-height: 1.5;
    text-align: center;
  }

  @media (max-width: 900px) {
    .pdf-top-tools {
      margin-bottom: 0.625rem;
    }
  }
</style>
