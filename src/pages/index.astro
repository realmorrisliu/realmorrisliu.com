---
import Layout from "@layouts/Layout.astro";
import Link from "@components/Link.astro";
import FooterSignature from "@components/FooterSignature.astro";
import CurrentStatus from "@components/CurrentStatus.astro";
import "@styles/global.css";
---

<Layout
  title="Morris Liu - Rust Systems Builder & Agent Runtime Architect"
  description="Morris Liu: 7+ years building Rust systems & AI infrastructure. Former CTO scaling teams 20+. Building agent runtimes (Marco & Alan), open-source LLM tooling (openrouter-rs), and indie games. Rust-first, agent-first."
  imageAlt="Morris Liu - Rust systems builder and agent runtime architect, open source contributor"
>
  <div class="mx-auto max-w-2xl px-6 py-16">
    <div class="space-y-8 leading-relaxed">
      <h1 class="text-text-primary font-serif text-4xl leading-tight">Hi, I'm Morris.</h1>

      <CurrentStatus />

      <div class="text-text-secondary space-y-6 text-lg">
        <p>
          I build systems in Rust, with a focus on agent runtimes and AI infrastructure. Over 7
          years, I've scaled from individual contributor to CTO, led engineering teams of 20+
          people, and built enterprise platforms serving production workloads with 99.9%+ uptime.
        </p>

        <p>
          Currently building agent runtimes—<Link href="https://github.com/realmorrisliu/Alan"
            >Alan</Link
          > (open-source, the foundation for all my future agents) and Marco (production, at work). My
          open source projects also include <Link
            href="https://github.com/realmorrisliu/openrouter-rs">openrouter-rs</Link
          > (type-safe Rust SDK for OpenRouter with 100% API coverage) and <Link
            href="https://github.com/realmorrisliu/funcall">funcall</Link
          > (Rust macro for turning functions into JSON tools).
        </p>

        <p>
          I share deep technical insights in my
          <Link href="/thoughts">thoughts</Link>, covering agent architecture, Rust systems
          programming, and startup engineering. Learn more about my professional journey and
          projects
          <Link href="/so-far">so far</Link>.
        </p>

        <p>
          Outside of code, I practice bass and capture <Link href="/moments">moments</Link> through photography—both
          teach me about rhythm, timing, and finding beauty in structure.
        </p>
      </div>
    </div>

    <FooterSignature />
  </div>
</Layout>
