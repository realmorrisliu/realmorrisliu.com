---
import Layout from "@layouts/Layout.astro";
import Link from "@components/Link.astro";
import FooterSignature from "@components/FooterSignature.astro";
import CurrentStatus from "@components/CurrentStatus.astro";
import "@styles/global.css";
---

<Layout
  title="Morris Liu - Systems Builder & Engineering Leader"
  description="Morris Liu builds Rust systems across CAD, computer graphics, agent runtimes, and AI infrastructure. Returning to EverXYZ to rebuild its technical team while continuing Alan and open-source Rust tooling."
  imageAlt="Morris Liu - systems builder, engineering leader, and open source contributor"
>
  <div class="mx-auto max-w-2xl px-6 py-16">
    <div class="space-y-8 leading-relaxed">
      <h1 class="text-text-primary font-serif text-4xl leading-tight">Hi, I'm Morris.</h1>

      <CurrentStatus />

      <div class="text-text-secondary space-y-6 text-lg">
        <p>
          I build systems in Rust across CAD, computer graphics, agent runtimes, and AI
          infrastructure. Since 2017, I've grown from individual contributor to CTO, led engineering
          teams of 20+ people, and built enterprise platforms used in production.
        </p>

        <p>
          I'm returning to EverXYZ to rebuild its technical team and work on CAD and computer
          graphics. Alongside that, I build <Link href="https://github.com/realmorrisliu/Alan"
            >Alan</Link
          >, an open-source, Plan 9-inspired programmable personal computing environment. My other
          Rust projects include <Link href="https://github.com/realmorrisliu/openrouter-rs"
            >openrouter-rs</Link
          >, a type-safe SDK and CLI for OpenRouter, and <Link
            href="https://github.com/realmorrisliu/funcall">funcall</Link
          >, a small macro for turning Rust functions into JSON tools.
        </p>

        <p>
          I share deep technical insights in my
          <Link href="/thoughts">thoughts</Link>, covering agent architecture, Rust systems
          programming, and startup engineering. Learn more about my professional journey and
          projects
          <Link href="/so-far">so far</Link>.
        </p>

        <p>
          Outside of code, I practice bass, ride and tinker with my Aceoffix D10, and capture <Link
            href="/moments">moments</Link
          > through photography. They sharpen my sense of rhythm, mechanics, and the difference between
          something that merely works and something that feels right.
        </p>
      </div>
    </div>

    <FooterSignature />
  </div>
</Layout>
