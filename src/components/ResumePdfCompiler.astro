---
import { type Language } from "@i18n/utils";

interface Props {
  currentLang: Language;
}

const { currentLang } = Astro.props;
const mainPath = currentLang === "zh" ? "resume.zh.typ" : "resume.en.typ";
const dataUrl = currentLang === "zh" ? "/so-far/pdf-data/zh.json" : "/so-far/pdf-data/en.json";
const dataPath = currentLang === "zh" ? "resume.zh.json" : "resume.en.json";
const fileName = currentLang === "zh" ? "morris-liu-resume-zh.pdf" : "morris-liu-resume.pdf";
const wasmBaseUrl = (
  import.meta.env.PUBLIC_RESUME_TYPST_WASM_BASE_URL ?? "/resume-typst-wasm"
).replace(/\/$/, "");

const statusCopy =
  currentLang === "zh"
    ? {
        loading: "正在加载 Typst 编译器",
        compiling: "正在渲染预览",
        ready: "预览已生成",
        pdf: "正在生成 PDF",
        failed: "编译失败",
      }
    : {
        loading: "Loading Typst compiler",
        compiling: "Rendering preview",
        ready: "Preview is ready",
        pdf: "Generating PDF",
        failed: "Compile failed",
      };
---

<div
  id="resume-pdf-app"
  class="text-resume-body mx-auto h-[297mm] w-[210mm] border border-black bg-white px-5 py-3 font-sans leading-tight text-black"
  data-state="loading"
  data-lang={currentLang}
  data-main-path={mainPath}
  data-data-path={dataPath}
  data-data-url={dataUrl}
  data-file-name={fileName}
  data-font-urls='["/resume-typst/fonts/NotoSansCJKsc-Regular.otf"]'
  data-wasm-base-url={wasmBaseUrl}
  data-status-loading={statusCopy.loading}
  data-status-compiling={statusCopy.compiling}
  data-status-ready={statusCopy.ready}
  data-status-pdf={statusCopy.pdf}
  data-status-failed={statusCopy.failed}
>
  <span id="resume-pdf-status" class="sr-only">{statusCopy.loading}</span>
  <div
    id="resume-pdf-preview"
    class="flex h-full w-full items-center justify-center text-center text-sm text-gray-500"
  >
    {statusCopy.loading}
  </div>
  <pre
    id="resume-pdf-error"
    class="mt-3 hidden max-h-32 overflow-auto border border-red-200 bg-red-50 p-2 text-xs whitespace-pre-wrap text-red-800 print:hidden">
  </pre>
</div>

<script>
  import "@/scripts/resume-pdf-runtime";
</script>
